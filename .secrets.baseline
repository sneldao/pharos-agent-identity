# Secret-scan baseline. Each line: <fingerprint>  <rule>  <file:line>
# Regenerate with: bash tools/secret-scan.sh --update-baseline
#
# Format: <16-char sha256 fingerprint>  <rule-name>  <file:line>
# Add an entry to suppress a false positive. The fingerprint is computed
# from "<file>:<matched-line>".
