{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "composite": true
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../core/tsconfig.json" },
    { "path": "../adapter-evm/tsconfig.json" },
    { "path": "../adapter-casper/tsconfig.json" },
    { "path": "../agent-logic/tsconfig.json" },
    { "path": "../zerog/tsconfig.json" }
  ],
  "exclude": ["node_modules", "dist"]
}
