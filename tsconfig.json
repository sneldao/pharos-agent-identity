{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@ligis/core": ["packages/core/src/index.ts"],
      "@ligis/adapter-evm": ["packages/adapter-evm/src/index.ts"],
      "@ligis/adapter-casper": ["packages/adapter-casper/src/index.ts"],
      "@ligis/agent-logic": ["packages/agent-logic/src/index.ts"],
      "@ligis/zerog": ["packages/zerog/src/index.ts"],
      "@ligis/cli": ["packages/cli/src/index.ts"],
      "@ligis/mcp-server": ["packages/mcp-server/src/index.ts"],
      "@ligis/x402-server": ["packages/x402-server/src/index.ts"]
    }
  },
  "references": [
    { "path": "packages/core/tsconfig.json" },
    { "path": "packages/adapter-evm/tsconfig.json" },
    { "path": "packages/adapter-casper/tsconfig.json" },
    { "path": "packages/zerog/tsconfig.json" },
    { "path": "packages/agent-logic/tsconfig.json" },
    { "path": "packages/cli/tsconfig.json" },
    { "path": "packages/mcp-server/tsconfig.json" },
    { "path": "packages/x402-server/tsconfig.json" }
  ]
}
