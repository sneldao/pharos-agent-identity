# dependencies
/lib/
node_modules/
/packages/*/dist/
/packages/*/node_modules/
out/
cache/
broadcast/

# package build outputs
dist/

# typescript incremental build cache
*.tsbuildinfo

# secrets — never commit these
.env
.env.local
.env.*.local
.env.d/
*.key
*.pem
*.p12
*.pfx
*.secret
secrets/
deployments/localhost/

# deployment records (contain live addresses + deployer info)
.deployment-latest.json

# editor
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# test artifacts
coverage/
coverage.json
lcov.info
gas-report.txt

# foundry debug
debug.log
.trace

# npm
.npm
.npmrc

# claude code / commandcode / agent session-local config
.claude/
.commandcode/
.junie/
.agents/
.casper/

# video project — source tracked, rendered output + captures ignored
/video/*/ligis-demo.mp4
/video/*/renders/
/video/*/thumbs/
/video/*/assets/images/
/video/*/assets/audio/
/video/*/assets/captures/
/video/*/node_modules/
/video/*/package-lock.json

# accidental build output of an earlier tsc run — not the real package
# (real one is packages/adapter-casper/); keep ignored unless user confirms
/CredentialRegistry/
