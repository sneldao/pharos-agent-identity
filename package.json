{
  "name": "ligis",
  "version": "0.1.0",
  "description": "Ligis — Chain-agnostic Identity & Verifiable Credentials Skill for AI agents. Portable agent IDs, signed capability credentials, key rotation, and revocation. Pluggable chain adapters (EVM/Pharos today; Casper next), with 0G Compute for reasoning and 0G Storage for verifiable evidence.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "start": "node --enable-source-maps packages/cli/dist/index.js",
    "mcp": "node --enable-source-maps packages/mcp-server/dist/index.js",
    "mcp:dev": "tsx packages/mcp-server/src/index.ts",
    "x402": "node --enable-source-maps packages/x402-server/dist/index.js",
    "x402:dev": "tsx watch packages/x402-server/src/index.ts",
    "test": "bash scripts/forge.sh test -vvv",
    "test:ts": "node --import tsx --test packages/*/test/**/*.test.ts",
    "test:all": "bash scripts/forge.sh test -vvv && pnpm run test:ts",
    "test:coverage": "bash scripts/forge.sh coverage",
    "deploy:atlantic": "bash scripts/deploy.sh atlantic",
    "verify:atlantic": "bash scripts/verify.sh atlantic",
    "demo": "bash scripts/demo.sh",
    "format": "bash scripts/forge.sh fmt && prettier --write 'packages/*/src/**/*.{ts,json,md}'",
    "clean": "pnpm -r run clean && rm -rf out cache broadcast"
  },
  "keywords": [
    "pharos",
    "agent",
    "skill",
    "identity",
    "credentials",
    "eip-712",
    "erc-721",
    "mcp",
    "ai-agent",
    "web3"
  ],
  "devDependencies": {
    "prettier": "^3.3.0",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=20"
  }
}
